# Base URL for the app (used by Vite and React Router)
# Set to "/" for custom domain (e.g. badbyte.dev) or for Netlify
# Set to "/bad_bytes/" for GitHub Pages deployment
VITE_BASE_URL=/

# --- Server-side only (Netlify Functions) ---
# These are NOT exposed to the browser. Set them in the Netlify UI:
# Site settings -> Environment variables.
RESEND_API_KEY=
TO_EMAIL=badbyte26@gmail.com
# Optional. Defaults to "Bad Byte <onboarding@resend.dev>" (Resend's testing sender).
# Use a real From only after you verify a custom domain in Resend.
FROM_EMAIL=
